generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum bookingStatus{
    PENDING
    CONFIRMED
    CANCELLED
}

enum showSeat{
  AVAILABLE
  BOOKED
}
enum seatType{
  STANDARD
  PREMIUM
  BALCONY
}
model User{
  id String @id @default(cuid())
  phone String @unique
  name String
  gender String
  age  Int 
  bookings Booking[]

}

model Booking{
  id String @id @default(cuid())
  userId String 
  bookingTime DateTime
  totalAmount Decimal 
  status bookingStatus
  bookingSeats  BookingSeat[]
  showId String
  invoice   Invoice?
  show   Show @relation(fields: [showId], references: [id])
  user User @relation(fields: [userId],references: [id])
  @@index([userId])
}

model BookingSeat{
  id String @id @default(cuid())
  bookingId String 
  showSeatId String @unique 
  booking Booking @relation(fields: [bookingId],references: [id])
  showSeat ShowSeat @relation(fields: [showSeatId],references: [id])
  @@index([bookingId])
}

model ShowSeat{
  id String @id @default(cuid())
  showId String
  seatId String
  status showSeat @default(AVAILABLE)
  show Show @relation(fields: [showId],references: [id])
  seat Seat @relation(fields: [seatId],references: [id])
  bookingSeat BookingSeat?
  @@unique([showId, seatId])
  @@index([showId])
}

model Show{
  id String @id @default(cuid())
  movieId String 
  screenId String 
  startTime DateTime
  endTime DateTime
  pricings  ShowSeatPricing[]
  movie Movie @relation(fields: [movieId],references: [id])
  screen Screen @relation(fields: [screenId],references: [id])
  showSeats ShowSeat[]
  bookings Booking[]
  @@index([movieId])
  @@index([screenId])
}

model ShowSeatPricing {
  id       String @id @default(cuid())

  showId   String
  seatType seatType
  price    Decimal
  show     Show @relation(fields: [showId], references: [id])
  @@unique([showId, seatType])
}
model Seat{
  id String @id @default(cuid())     
  screenId String 
  seatNumber String
  seatType seatType 
  screen Screen @relation(fields: [screenId],references: [id])
  showseats ShowSeat[]
  @@unique([screenId, seatNumber])
}

  model Movie{
    id String @id @default(cuid())   
    name String 
    releaseDate  DateTime
    rating Decimal 
    cast   String
    director String
    producer String 
    durationMinutes Int 
    language String
    shows Show[]
    @@index([name])
    @@unique([name,language])
  }

model Screen{
  id String @id @default(cuid())   
  screenNumber Int 
  theatreId String
  theatre Theatre @relation(fields: [theatreId],references: [id])
  seats Seat[]
  shows Show[]
  @@unique([theatreId,screenNumber])
  @@index([theatreId])
}

model Theatre{
  id String @id @default(cuid())
  name String 
  address String
  city String
  pincode Int
  screens Screen[]
  @@unique([name,address])
}

model Invoice {
  id          String   @id @default(cuid())

  invoiceNo   String   @unique

  bookingId   String   @unique

  subTotal    Decimal
  tax         Decimal
  total       Decimal

  issuedAt    DateTime @default(now())

  booking Booking @relation(fields: [bookingId], references: [id])
}